rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: true when the caller is the super-admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == "kian@flosuites.ca";
    }

    // User profile documents
    match /users/{userId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
    }

    // Business cards (flat collection)
    match /cards/{userId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
    }

    // Slug mappings (vanity URLs)
    match /slugs/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
