rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile documents
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Business card subcollection
      match /profile/{docId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Slug mappings (vanity URLs)
    match /slugs/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
